# Supabase
# Dashboard → tu proyecto → Project Settings → API (no copies una URL de ejemplo: debe ser TU ref).
# Si ves net::ERR_NAME_NOT_RESOLVED, el host no existe en DNS (proyecto borrado/pausado, ref equivocada o red).
VITE_SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....

# URL de la app en producción. Obligatoria en Vercel: así el correo de recuperación de contraseña
# apunta a tu dominio (ej. https://tablero.vercel.app). En Supabase → Authentication → URL Configuration
# añade esta URL y también https://tu-dominio/reset-password en "Redirect URLs".
# VITE_APP_URL=https://tu-dominio.vercel.app

# Opcional — demo / pruebas: fija la fecha-hora de la app (ISO 8601). Quita o comenta en producción.
# El filtro type="date" de acciones en /dashboard y /kanban usa la fecha real (zona CDMX), no esta variable.
# Ej. 10 abr 2026, 16:58 hora Ciudad de México (UTC-6):
# VITE_DEV_FIXED_NOW=2026-04-10T16:58:00-06:00

# Solo para scripts de administración (ej. set-user-password.mjs). NO subir a git ni usar en frontend.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Edge Function calculate-distance: API key de Google con Routes API habilitada.
# Configurar en Supabase → Edge Functions → Secrets (no en este archivo para producción).
# GOOGLE_MAPS_API_KEY=...
