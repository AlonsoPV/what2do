{
  "name": "tablero-operativo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && node ./node_modules/vite/bin/vite.js build",
    "vercel-build": "npm run build",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "supabase:deploy": "npx supabase@latest functions deploy calculate-distance",
    "supabase:deploy:all": "npx supabase@latest functions deploy calculate-distance && npx supabase@latest functions deploy invite-user && npx supabase@latest functions deploy academy-generate-quiz && npx supabase@latest functions deploy send-notification-email && npx supabase@latest functions deploy google-workspace-sync && npx supabase@latest functions deploy google-reminder-complete",
    "academy:generate-pdfs": "node scripts/generate-academy-module-pdfs.mjs",
    "academy:audit-storage": "node scripts/audit-academy-storage.mjs",
    "test:kpi-smoke": "node --experimental-strip-types scripts/kpi-calculation-smoke.mts",
    "auth:password": "node scripts/set-user-password.mjs",
    "auth:password-batch": "node scripts/set-users-password-batch.mjs",
    "auth:create-analistas-emx": "node scripts/create-analistas-emx-batch.mjs",
    "auth:fix-users": "node --use-system-ca scripts/fix-auth-users-via-admin.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.47.10",
    "@tanstack/react-query": "^5.62.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-router-dom": "^7.0.1",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zustand": "^5.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.2",
    "vite": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "typescript-eslint": "^8.15.0",
    "vitest": "^4.1.2"
  }
}
